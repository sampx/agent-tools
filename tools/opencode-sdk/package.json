{
  "name": "opencode-sdk",
  "version": "1.0.0",
  "description": "OpenCode SDK and CLI",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "oc-cli": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.cli.json",
    "dev": "npx tsx cli/index.ts",
    "cli": "node dist/cli/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "clean": "rm -rf dist/",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "eventsource": "^4.1.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.5.0"
  },
  "files": [
    "dist/",
    "index.js",
    "index.d.ts",
    "api.js",
    "api.d.ts",
    "base.js",
    "base.d.ts",
    "common.js",
    "common.d.ts",
    "configuration.js",
    "configuration.d.ts",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "opencode",
    "sdk",
    "cli",
    "ai",
    "openapi"
  ],
  "license": "MIT"
}
